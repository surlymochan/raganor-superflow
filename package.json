{
  "name": "@raganor/superflow",
  "version": "1.0.0",
  "description": "跨平台超级工作流 - SDD + 一句话需求 + TDD + 对抗性验证的长程模糊任务最佳帮手",
  "slogan": "跨平台的超级工作流 - SDD + 一句话需求 + TDD + 对抗性验证的长程模糊任务的最佳帮手！",
  "author": "Raganor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/surlymochan/raganor-superflow.git"
  },
  "bugs": {
    "url": "https://github.com/surlymochan/raganor-superflow/issues"
  },
  "homepage": "https://github.com/surlymochan/raganor-superflow#readme",
  "keywords": [
    "claude-code",
    "opencode",
    "cursor",
    "workflow",
    "sdd",
    "tdd",
    "agent",
    "ai-coding",
    "developer-tools"
  ],
  "scripts": {
    "install:claude-code": "node scripts/install-claude-code.js",
    "install:opencode": "node scripts/install-opencode.js",
    "install:cursor": "node scripts/install-cursor.js",
    "install:all": "npm run install:claude-code && npm run install:opencode && npm run install:cursor",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint scripts/",
    "validate": "node scripts/validate-norm.js",
    "validate:norm": "node scripts/validate-github-norm.js",
    "validate:workflows": "action-validator .github/workflows/*.yml",
    "init:norm": "node scripts/init-github-norm.js"
  },
  "files": [
    "config/",
    "scripts/",
    "commands/",
    "skills/"
  ],
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "openai": "^4.0.0",
    "dotenv": "^16.0.0"
  }
}
